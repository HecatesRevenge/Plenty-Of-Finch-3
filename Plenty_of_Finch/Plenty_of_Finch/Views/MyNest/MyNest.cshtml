@using Plenty_of_Finch.Models.MyNest.MyNest_Classes
@model MyNestViewModel

@{
    ViewData["Title"] = "MyNest";
}

<div class="container my-4 flex-grow-1">

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        string messageType = "text-warning";


        if (Model.MessageVisible)
        {
            messageType = "text-success";
        }
        <div class="d-block mb-3 fw-bold text-center @messageType">
            @Model.Message
        </div>
    }
    @*Liked Profiles*@
    <div class="card p-4 mx-auto mb-4" style="max-width: 900px; background-color: #1e293b; border: 2px solid #334155;">
        <h3 class="text-center mb-4" style="color: #ef4444;">My Nest</h3>
        <p class="text-center" style="color: #94a3b8;">These are the birds you've saved to your flock.</p>


        @* This checks liked dating profiles is empty and returns error message*@

        @if (Model.NestBirdProfiles.Count == 0)
        {
            <p class="text-center" style="color: #94a3b8;">
                Nest is Empty. Go to Search Page to Find Your Flock!
            </p>
        }
        else
        {
            foreach (NestBirdProfiles bird in Model.NestBirdProfiles)
            {
                string profileImg = bird.ProfileImage;
                if (string.IsNullOrEmpty(profileImg))
                {
                    profileImg = "/images/default-profile.png"; // Replace with your default image path
                }

                @*TODO this might become reusable so later on see if I can move to own class for max code reusability*@ 
                                                                                                                                                                                                                                                                                                                                @* Creates a profile view in for each profile in the myNest page. *@
                <div class="card mb-3 p-3" style="background-color: #334155;">
                    <div class="d-flex align-items-center">
                        <img src="@profileImg" class="rounded-circle border border-secondary me-3"
                             style="width: 50px; height: 50px; object-fit: cover;" />
                        <div class="flex-grow-1">
                            <strong style="color: #f8fafc;">@bird.FirstName @bird.LastName</strong>
                            <span class="text-muted ms-2">Age @bird.Age</span>
                            <br />
                            <span style="color: #94a3b8;">@bird.Species &bull; @bird.City, @bird.State</span>
                        </div>
                        <a href="/DatingProfile/DatingProfile?id=@bird.BirdID"
                           class="btn btn-sm me-2" style="background-color: #ef4444; color: white;">View Profile</a>
                        <a href="/MyNest/Remove?birdID=@bird.BirdID"
                           class="btn btn-sm btn-outline-danger">Remove</a>
                    </div>
                </div>
            }
        }
    </div>

    @*Upcoming Dates*@
    <div class="card p-4 mx-auto mb-4" style="max-width: 900px; background-color: #1e293b; border: 2px solid #334155;">
        <h3 class="text-center mb-4" style="color: #ef4444;">Upcoming Dates</h3>
        <p class="text-center" style="color: #94a3b8;">Birds who accepted your date request or whose request you accepted.</p>

        @if (Model.UpcomingDates.Count == 0)
        {
            <p class="text-center" style="color: #94a3b8;">
                No Upcoming Dates. Go Send Date Requests to Your Matches
            </p>
        }
        else
        {
            foreach (UpcomingDates dates in Model.UpcomingDates)
            {
                string profileImg = dates.ProfileImage;
                if (string.IsNullOrEmpty(profileImg))
                {
                    profileImg = "/images/default-profile.png";
                }

                <div class="card mb-3 p-4" style="background-color: #334155;">

                    <div class="d-flex align-items-center" mb-3>
                        <img src="@profileImg" class="rounded-circle border border-secondary me-3" style="width: 70px; height: 70px; object-fit: cover;" />
                        <div>
                            <h5 class="mb-0" style="color: #f8fafc;">@dates.FirstName @dates.LastName</h5>
                            <span style="color: #94a3b8;">@dates.Species &bull; @dates.Age &bull; @dates.Gender</span>
                        </div>
                        <a href="/DatingProfile/DatingProfile?id=@dates.BirdID" class="btn btn-sm ms-auto" style="background-color: #ef4444; color: white;">View Profile</a>
                    </div>

                    <p style="color: #cbd5e1;">@dates.Biography</p>


                    <div class="row">
                        <div class="col-md-6">
                            <p style="color: #94a3b8;"><strong style="color: #f8fafc;">Location:</strong> @dates.City, @dates.State</p>
                            <p style="color: #94a3b8;"><strong style="color: #f8fafc;">Occupation:</strong> @dates.Occupation</p>
                        </div>
                        <div class="col-md-6">
                            <h6 style="color: #22c55e; border-bottom: 1px solid #475569; padding-bottom: 5px;">Contact Info</h6>
                            <p style="color: #94a3b8;"><strong style="color: #f8fafc;">Email:</strong> @dates.Email</p>
                            <p style="color: #94a3b8;"><strong style="color: #f8fafc;">Phone:</strong> @dates.PhoneNumber</p>
                            <p style="color: #94a3b8;"><strong style="color: #f8fafc;">Address:</strong> @dates.HomeAddress</p>
                        </div>
                    </div>

                </div>



            }
        }
    </div>



    @* TODO: 
    
        Add Yelp API integration somewhere here. It needs to give suggestions during the date planning and display the same info in the Planned Dates section
        It also needs to be added to the upcoming dates form. 
        
    *@

    @*Date Planning*@
    <div class="card p-4 mx-auto mb-4" style="max-width: 900px; background-color: #1e293b; border: 2px solid #334155;">
        <h3 class="text-center mb-4" style="color: #ef4444;">Plan a Date</h3>
        <p class="text-center" style="color: #94a3b8;">Select a Match and Set Up a Date.</p>


        <form asp-controller="MyNest" asp-action="PlanDate" method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="MatchID" class="form-label" style="color: #f8fafc;">Choose a Match</label>
                    <select name="MatchID" class="form-select">
                        <option value="">Select a Match</option>
                        @foreach (Microsoft.AspNetCore.Mvc.Rendering.SelectListItem match in Model.MatchOptions)
                        {
                            if (match.Value != "")
                            {
                                <option value="@match.Value">@match.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label asp-for="DateTime" class="form-label" style="color: #f8fafc;">Date & Time</label>
                    <input asp-for="DateTime" type="datetime-local" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label asp-for="Location" class="form-label" style="color: #f8fafc;">Location</label>
                    <input asp-for="Location" class="form-control" placeholder="Rittenhouse Square" />
                </div>

                <div class="col-md-6">
                    <label asp-for="Description" class="form-label" style="color: #f8fafc;">Description</label>
                    <input asp-for="Description" class="form-control" placeholder="Birdwatching" />
                </div>

                <div class="col-12">
                    <button type="submit" class="btn fw-bold w-100" style="background-color: #ef4444; color: white;">Plan Date</button>
                </div>
            </div>
        </form>
    </div>

    @*Planned Dates*@
    <div class="card p-4 mx-auto mb-4" style="max-width: 900px; background-color: #1e293b; border: 2px solid #334155;">
        <h3 class="text-center mb-4" style="color: #ef4444;">Planned Dates</h3>



        @if (Model.PlannedDates.Count == 0)
        {
            <p class="text-center" style="color: #94a3b8;">
                No Planned Dates. Use Date Planner to Set Up Dates with Your Matches!
            </p>
        }
        else
        {
            foreach (PlannedDates planned in Model.PlannedDates)
            {
                string profileImg = planned.ProfileImage;

                if (string.IsNullOrEmpty(profileImg))
                {
                    profileImg = "/images/default-profile.png";
                }

                <div class="card mb-3 p-3" style="background-color: #334155;">

                    <div class="d-flex align-items-center mb-2">
                        <img src="@profileImg" class="rounded-circle border border-secondary me-3"
                             style="width: 50px; height: 50px; object-fit: cover;" />
                        <div>
                            <strong style="color: #f8fafc;">@planned.FirstName @planned.LastName</strong>
                            <span class="text-muted ms-2">(@planned.Species)</span>
                        </div>
                    </div>
                    <div class="ms-5">
                        <p style="color: #f8fafc;"><strong style="color: #ef4444;">When:</strong> @planned.DateOfDate.ToString("MMM dd, yyyy h:mm tt")</p>
                        <p style="color: #f8fafc;"><strong style="color: #ef4444;">Where:</strong> @planned.Location</p>
                        <p style="color: #f8fafc;"><strong style="color: #ef4444;">Plan:</strong> @planned.Description</p>
                    </div>
                </div>


            }
        }


    </div>
</div>