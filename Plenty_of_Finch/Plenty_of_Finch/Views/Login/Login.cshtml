@model Plenty_of_Finch.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
}
<main class="flex-grow-1 d-flex justify-content-center align-items-center my-5">
    <div style="width: 100%; max-width: 400px; padding: 0 15px;">
        <div class="card shadow-lg p-4" style="background-color: #1e293b; border: 4px solid #334155;">

            <div class="text-center mb-4">
                <h2 style="color: #ef4444;">Welcome Back!</h2>
                <p style="color: #cbd5e1;">Ready To Find Your Finch?</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="mb-3 text-center">
                    <span class="text-danger fw-bold">@Model.ErrorMessage</span>
                </div>
            }

            <form method="post" action="/Login/Login">

                <div class="mb-3">
                    <label class="form-label" style="color: #f8fafc;">Username</label>
                    <input type="text" name="Username" value="@Model.Username"
                           class="form-control" placeholder="Username" />
                </div>

                <div class="mb-3">
                    <label class="form-label" style="color: #f8fafc;">Password</label>
                    <input type="password" name="Password" value=""
                           class="form-control" placeholder="Password" />
                </div>

                <div class="mb-3 form-check">
                    @if (Model.RememberMe)
                    {
                        <input type="checkbox" name="RememberMe" value="true"
                               class="form-check-input" checked="checked" />
                    }
                    else
                    {
                        <input type="checkbox" name="RememberMe" value="true"
                               class="form-check-input" />
                    }
                    <label class="form-check-label" style="color: #94a3b8;">Remember Me</label>
                </div>

                @* Delete cookie link (only shown if cookie exists) *@
                @if (Model.RememberMe)
                {
                    <div class="mb-3 text-center">
                        <small>
                            <a href="/Login/DeleteCookie" style="color: #94a3b8; text-decoration: none;">
                                Clear saved username
                            </a>
                        </small>
                    </div>
                }

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn fw-bold"
                            style="background-color: #ef4444; color: white;">
                        Log In
                    </button>
                </div>

            </form>

            <div class="text-center mt-3">
                <small style="color: #cbd5e1;">
                    Don't have an account?
                    <a href="/Register/Register" style="color: #f87171; text-decoration: none;">Sign up here</a>
                </small>
            </div>

            <div class="text-center mt-2">
                <small>
                    <a href="/Login/ForgotPassword" style="color: #94a3b8; text-decoration: none;">Forgot Password?</a>
                    &nbsp;|&nbsp;
                    <a href="/Login/ForgotUsername" style="color: #94a3b8; text-decoration: none;">Forgot Username?</a>
                </small>
            </div>

        </div>
</main>