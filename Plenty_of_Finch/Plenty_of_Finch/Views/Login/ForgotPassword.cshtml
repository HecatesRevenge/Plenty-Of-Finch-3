@using Plenty_of_Finch.Models.Login
@model ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}
<main class="flex-grow-1 d-flex justify-content-center align-items-center my-5">
    <div style="width: 100%; max-width: 450px; padding: 0 15px;">
        <div class="card shadow-lg p-4" style="background-color: #1e293b; border: 4px solid #334155;">

            <div class="text-center mb-4">
                <h2 style="color: #ef4444;">Reset Password</h2>
                <p style="color: #cbd5e1;">Answer your security question to reset your password.</p>
            </div>


            @*These will return a success or error message if user is able to recover password or inputs info in the wrong format*@
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="mb-3 text-center">
                    <span class="text-danger fw-bold">@Model.ErrorMessage</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="mb-3 text-center">
                    <span class="text-success fw-bold">@Model.SuccessMessage</span>
                </div>
                <div class="text-center mt-3">
                    <a href="/Login/Login" class="btn fw-bold"
                       style="background-color: #ef4444; color: white;">Back to Login</a>
                </div>
            }

            @if (Model.Step == 1)
            {
                <form method="post" action="/Login/ForgotPassword">
                    <input type="hidden" name="Step" value="1" />

                    <div class="mb-3">
                        <label class="form-label" style="color: #f8fafc;">Username</label>
                        <input type="text" name="Username" value="@Model.Username"
                               class="form-control" placeholder="Enter your username" />
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn fw-bold"
                                style="background-color: #ef4444; color: white;">
                            Next
                        </button>
                    </div>
                </form>
            }

            @if (Model.Step == 2)
            {
                <form method="post" action="/Login/ForgotPassword">
                    <input type="hidden" name="Step" value="2" />
                    <input type="hidden" name="Username" value="@Model.Username" />
                    <input type="hidden" name="SecurityQuestion" value="@Model.SecurityQuestion" />

                    <div class="mb-3">
                        <label class="form-label" style="color: #f8fafc;">Security Question</label>
                        <p style="color: #94a3b8;" class="fw-bold">@Model.SecurityQuestion</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="color: #f8fafc;">Your Answer</label>
                        <input type="text" name="SecurityAnswer" value=""
                               class="form-control" placeholder="Enter your answer" />
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn fw-bold"
                                style="background-color: #ef4444; color: white;">
                            Verify
                        </button>
                    </div>
                </form>
            }

            @if (Model.Step == 3)
            {
                <form method="post" action="/Login/ForgotPassword">
                    <input type="hidden" name="Step" value="3" />
                    <input type="hidden" name="Username" value="@Model.Username" />

                    <div class="mb-3">
                        <label class="form-label" style="color: #f8fafc;">New Password</label>
                        <input type="password" name="NewPassword" value=""
                               class="form-control" placeholder="Enter new password" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="color: #f8fafc;">Confirm Password</label>
                        <input type="password" name="ConfirmPassword" value=""
                               class="form-control" placeholder="Confirm new password" />
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn fw-bold"
                                style="background-color: #ef4444; color: white;">
                            Reset Password
                        </button>
                    </div>
                </form>
            }
            <div class="text-center mt-3">
                <small>
                    <a href="/Login/Login" style="color: #94a3b8; text-decoration: none;">Back to Login</a>
                </small>
            </div>

        </div>
    </div>
</main>