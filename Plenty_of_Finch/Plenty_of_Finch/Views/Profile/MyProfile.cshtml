@using Plenty_of_Finch.Models.Profile
@model MyProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="container my-4 flex-grow-1">
   
    

    @*

    Fix this once API is implemented 
    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="d-block mb-3 fw-bold text-success text-center">
            @Model.Message
        </div>
    }
    *@


    @foreach (Notification note in Model.Notifications)
    {
        <div class="alert @note.CssClass text-center mx-auto mb-2" style="max-width 900px;">
            @Html.Raw(note.Text)
        </div>

    }


    @*Profile Section*@
    <div class="card p-4 mx-auto mb-4" style="max-width: 900px; background-color: #1e293b; border: 2px solid #334155">
        <h3 class="text-center mb-4" style="color:#ef4444;">@Model.PageTitle</h3>
        <form asp-controller="Profile" asp-action="SaveProfile" method="post">
            <div class="row">
                <div class="col-md-6">

                    <h5 style="color: #ef4444; border-bottom: 2px solid #334155; padding-bottom: 5px;">About You</h5>

                    <div class="mb-3">
                        <label asp-for="Biography" class="form-label" style="color: #f8fafc">Biography</label>
                        <textarea asp-for="Biography" class="form-control" rows="4"></textarea>
                    </div>

                    @*Add File Upload Functionality*@
                    <div class="mb-3">
                        <label asp-for="ProfileImage" class="form-label" style="color: #f8fafc">Profile Image Upload</label>
                        <input asp-for="ProfileImage" type="file" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Species" class="form-label" style="color: #f8fafc;">Species</label>
                        <input asp-for="Species" class="form-control" placeholder="Cobra Chicken" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Wingspan" class="form-label" style="color: #f8fafc;">Wingspan (inches)</label>
                        <input asp-for="Wingspan" type="number" class="form-control" placeholder="12" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Plumage" class="form-label" style="color: #f8fafc;">Plumage</label>
                        <input asp-for="Plumage" class="form-control" placeholder="Rainbow" />
                    </div>
                </div>

                <div class="col-md-6">
                    <h5 style="color: #ef4444; border-bottom: 2px solid #334155; padding-bottom: 5px;">Preferences</h5>

                    <div class="mb-3">
                        <label asp-for="Occupation" class="form-label" style="color: #f8fafc;">Occupation</label>
                        <input asp-for="Occupation" class="form-control" placeholder="Butterfly Therapist" />

                        <div class="mb-3">
                            <label asp-for="FavoriteSeed" class="form-label" style="color: #f8fafc;">Favorite Seed</label>
                            <input asp-for="FavoriteSeed" class="form-control" placeholder="Good Seed" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" style="color: #f8fafc;">Commitment Type</label>
                            <select name="CommitmentType" class="form-select">
                                <option value="">Select...</option>
                                <option value="Nest Builder">Nest Builder</option>
                                <option value="Migratory Fling">Migratory Fling</option>
                                <option value="Mating for Life">Mating for Life</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Goals" class="form-label" style="color: #f8fafc;">Goals</label>
                            <input asp-for="Goals" class="form-control" placeholder="Find a nesting partner" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="AgeRange" class="form-label" style="color: #f8fafc;">Preferred Age Range</label>
                            <input asp-for="AgeRange" class="form-control" placeholder="22-30" />
                        </div>

                        <div class="mb-3">
                            <input asp-for="IsVisible" type="checkbox" checked="@Model.IsVisible" />
                            <label class="form-label" style="color: #f8fafc;">Make Profile visible</label>
                        </div>

                    </div>
                </div>
            </div>

            <h5 class="mt-3" style="color: #ef4444; border-bottom: 2px solid #334155; padding-bottom: 5px;">Likes & Dislikes</h5>
            <div class="row">
                <div class="row">
                    <div class="col-md-6">
                        <label asp-for="Likes" class="form-label" style="color: #f8fafc">Likes</label>
                        <textarea asp-for="Likes" class="form-control" rows="4" placeholder="Sunbathing, Worms, Long Flights"></textarea>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Dislikes" class="form-label" style="color: #f8fafc">Dislikes</label>
                        <textarea asp-for="Dislikes" class="form-control" rows="4" placeholder="Rainy Days, Loud Noises, Predators"></textarea>
                    </div>


                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-lg fw-bold" style="background-color: #ef4444; color: white;">Save Profile</button>
                </div>

            </div>
        </form>
    </div>

    <div class="card p-4 mx-auto mb-4" style="max-width: 900px; background-color: #1e293b; border: 2px solid #334155;">
        <h3 class="text-center mb-4" style="color: #ef4444;">Date Requests</h3>


        <h5 style="color: #f8fafc; border-bottom: 2px solid #334155; padding-bottom: 5px;">Incoming Requests</h5>

        @if (Model.IncomingRequests.Count == 0)
        {
            <p style="color: #94a3b8;">No incoming date requests.</p>
        }
        else
        {
            foreach (IncomingDateRequest req in Model.IncomingRequests)
            {
                string img = req.ProfileImage;
                if (string.IsNullOrEmpty(img))
                {
                    img = "DefaultProfileImage.png";
                }

                <div class="card mb-2 p-3" style="background-color: #334155;">
                    <div class="d-flex align-items-center">
                        <img src="@img" alt="Profile"
                             style="width: 60px; height: 60px; object-fit: cover; border-radius: 50%; margin-right: 15px;" />
                        <div style="flex: 1;">
                            <strong style="color: #f8fafc;">@req.SenderName</strong>
                            <span class="text-muted ms-2">(@req.SenderSpecies)</span>
                        </div>

                        @if (req.RequestStatus == "Pending")
                        {
                            <div>
                                <a href="/Profile/HandleRequest?action=accept&requestID=@req.RequestID"
                                   class="btn btn-sm" style="background-color: #22c55e; color: white;">Accept</a>
                                <a href="/Profile/HandleRequest?action=decline&requestID=@req.RequestID"
                                   class="btn btn-sm" style="background-color: #ef4444; color: white;">Decline</a>
                            </div>
                        }
                        else
                        {
                            string badgeColor = "#ef4444";
                            if (req.RequestStatus == "Accepted")
                            {
                                badgeColor = "#22c55e";
                            }
                            <span class="badge" style="background-color: @badgeColor;">@req.RequestStatus</span>
                        }
                    </div>
                </div>
            }
        }


        <h5 class="mt-4" style="color: #f8fafc; border-bottom: 2px solid #334155; padding-bottom: 5px;">Outgoing Requests</h5>

        @if (Model.OutgoingRequests.Count == 0)
        {
            <p style="color: #94a3b8;">No outgoing date requests.</p>
        }
        else
        {
            foreach (OutgoingDateRequest req in Model.OutgoingRequests)
            {
                string badgeColor = "#f59e0b";
                if (req.RequestStatus == "Accepted")
                {
                    badgeColor = "#22c55e";
                }
                if (req.RequestStatus == "Declined")
                {
                    badgeColor = "#ef4444";
                }

                <div class="card mb-2 p-3" style="background-color: #334155;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <strong style="color: #f8fafc;">@req.RecieverName</strong>
                            <span class="text-muted ms-2">(@req.ReceiverSpecies)</span>
                        </div>
                        <span class="badge" style="background-color: @badgeColor;">@req.RequestStatus</span>
                    </div>
                </div>
            }
        }
    </div>

    <div class="card p-4 mx-auto mb-4" style="max-width: 900px; background-color: #1e293b; border: 2px solid #334155;">
        <h3 class="text-center mb-4" style="color: #ef4444;">Viewed My Profile</h3>
        <p class="text-center d-block mb-3" style="color: #94a3b8;">
            Total views: @Model.TotalProfileViews
        </p>

        @if (Model.ProfileViewers.Count == 0)
        {
            <p class="text-center" style="color: #94a3b8;">No one has viewed your profile yet.</p>
        }
        else
        {
            foreach (ProfileViewer viewer in Model.ProfileViewers)
            {
                string img = viewer.ProfileImage;
                if (string.IsNullOrEmpty(img))
                {
                    img = "DefaultProfileImage.png";
                }

                <div class="card mb-3 p-3" style="background-color: #334155;">
                    <div class="d-flex align-items-center mb-2">
                        <img src="@img" class="rounded-circle border border-secondary me-3"
                             style="width: 40px; height: 40px; object-fit: cover;" />
                        <div>
                            <strong style="color: #f8fafc;">@viewer.FullName</strong>
                            <span class="text-muted ms-2">(@viewer.Species)</span>
                        </div>
                        <a href="/DatingProfile/DatingProfile?id=@viewer.ViewerID"
                           class="btn btn-sm ms-auto" style="background-color: #ef4444; color: white;">View Profile</a>
                    </div>
                    <div class="ms-5" style="color: #94a3b8; font-size: 0.9em;">
                        Viewed on @viewer.ViewedAt.ToString("MMM dd, yyyy h:mm tt")
                    </div>
                </div>
            }
        }
    </div>

 
    <div class="d-grid gap-2 mx-auto mb-4" style="max-width: 900px;">
        <a asp-controller="Profile" asp-action="Logout"
           class="btn btn-outline-danger btn-lg fw-bold">Log Out</a>
    </div>
</div>








