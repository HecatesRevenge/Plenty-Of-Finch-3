@using Plenty_of_Finch.Models.Search
@model SearchViewModel

@{
    ViewData["Title"] = "Search";
}
<div class="container my-5 flex-grow-1">
    <h2 class="mb-4" style="color: #ef4444;">Discover Your Flock</h2>

    <form asp-controller="Search" asp-action="Search" method="get">
        <div class="row g-3 align-items-end">

            <div class="col-md-2">
                <label class="text-small" style="color: #f8fafc;">State</label>
                <select name="SelectedState" class="form-select">
                    <option value="">Any State</option>
                    @foreach (string state in Model.StateOptions)
                    {
                        <option value="@state">@state</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="text-small" style="color: #f8fafc;">Looking For</label>
                <select name="SelectedCommitment" class="form-select">
                    <option value="">Any</option>
                    <option value="Nest Builder">Nest Builder</option>
                    <option value="Migratory Fling">Migratory Fling</option>
                    <option value="Mating for Life">Mating for Life</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="text-small" style="color: #f8fafc;">Age</label>
                <select name="SelectedAge" class="form-select">
                    <option value="">Any Age</option>
                    <option value="1-2">Fledgling (1-2 yrs)</option>
                    <option value="3-8">Prime Adult (3-8 yrs)</option>
                    <option value="8-15">Wise Elder (8-15 yrs)</option>
                    <option value="15-50">Ancient (15-50 yrs)</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="text-small" style="color: #f8fafc;">Wing Span</label>
                <select name="SelectedWingspan" class="form-select">
                    <option value="">Any</option>
                    <option value="Small">Small (0-20 in)</option>
                    <option value="Medium">Medium (20-40 in)</option>
                    <option value="Large">Large (41+ in)</option>
                </select>
            </div>

            <div class="col-md-1">
                <button type="submit" class="btn fw-bold w-100"
                        style="background-color: #ef4444; color: white;">
                    Search
                </button>
            </div>

        </div>
    </form>

    <hr style="border-color: #ef4444; border-width: 3px; margin-top: 1.5rem; margin-bottom: 1.5rem;" />

    @if (Model.Results.Count == 0)
    {
        <div class="text-center p-5" style="background-color: #334155; border-radius: 8px;">
            <h4 class="mt-3 text-white">No match found.</h4>
            <p style="color: #94a3b8;">There are no birds that match your search. Try adjusting your filters!</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (SearchResult bird in Model.Results)
            {
                string img = bird.ProfileImage;
                if (string.IsNullOrEmpty(img))
                {
                    img = "DefaultImage.png";
                }

                <div class="col mb-3" style="flex: 0 0 20%; max-width: 20%;">
                    <div class="card h-100" style="background-color: #334155; border: 1px solid #475569;">
                        <img src="@img" class="card-img-top" style="height: 120px; object-fit: cover;" />
                        <div class="card-body p-2">
                            <h6 class="card-title mb-1" style="color: #f8fafc; font-size: 0.85rem;">
                                @bird.FirstName @bird.LastName
                            </h6>
                            <p class="mb-1" style="color: #94a3b8; font-size: 0.75rem;">@bird.Species</p>
                            <p class="mb-1" style="color: #94a3b8; font-size: 0.75rem;">
                                Age @bird.Age; @bird.City, @bird.State
                            </p>
                            <a href="/DatingProfile/DatingProfile?id=@bird.BirdID"
                               class="btn btn-sm w-100" style="background-color: #ef4444; color: white; font-size: 0.75rem;">View</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>