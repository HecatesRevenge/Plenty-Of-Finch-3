@model RegisterViewModel

@{
    ViewData["Title"] = "Register";
}
<div class="container d-flex justify-content-center align-items-center mt-5 mb-5">
    <div class="card shadow-lg p-4" style="max-width: 800px; width: 100%; background-color: #1e293b; border: 4px solid #334155;">

        <div class="text-center mb-2">
            <h2 style="color: #ef4444;">Join Plenty of Finch!</h2>
            <p class="text" style="color: #f8fafc;">Create your account to find your perfect match.</p>
        </div>



        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="mb-3 text-center">
                <span class="text-danger fw-bold">@Model.ErrorMessage</span>
            </div>
        }

        <form asp-controller="Register" asp-action="Register" method="post">

            <div class="row">

                <div class="col-md-6">
                    <h5 style="color: #ef4444; border-bottom: 3px solid #334155; padding-bottom: 5px;">Personal Info</h5>


                    <div class="mb-3">
                        <label asp-for="FirstName" class="form-label" style="color: #f8fafc;">First Name</label>
                        <input asp-for="FirstName" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="LastName" class="form-label" style="color: #f8fafc;">Last Name</label>
                        <input asp-for="LastName" class="form-control" />
                    </div>

                    <div class="row">
                        <label asp-for="Age" class="form-label" style="color: #f8fafc;">Age</label>
                        <input asp-for="Age" class="form-control" type="number" />
                    </div>

                    <div class="col-6 mb-3">
                        <label asp-for="Gender" class="form-label" style="color: #f8fafc;">Gender</label>
                        <select asp-for="Gender" class="form-select">
                            <option value="">Select...</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>"
                            <option value="Non-Binary">Non-Binary</option>
                        </select>
                    </div>


                    <div class="mb-3">
                        <label asp-for="Email" class="form-label" style="color: #f8fafc;">Email</label>
                        <input asp-for="Email" class="form-control" type="email" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label" style="color: #f8fafc;">Phone Number</label>
                        <input asp-for="Phone" class="form-control" type="tel" placeholder="(215)-867-5309" />
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <h5 style="color: #ef4444; border-bottom: 3px solid #334155; padding-bottom: 5px;">Location</h5>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label" style="color: #f8fafc;">Home Address</label>
                    <input asp-for="Address" class="form-control" />
                </div>

                <div class="row">
                    <div class="col-8 mb-3">
                        <label asp-for="City" class="form-label" style="color: #f8fafc;">City</label>
                        <input asp-for="City" class="form-control" placeholder="Philadelphia" />
                    </div>

                    <div class="col-4 mb-3">
                        <label asp-for="State" class="form-label" style="color: #f8fafc;">State</label>
                        <input asp-for="State" class="form-control" maxlength="2" placeholder="PA" />
                    </div>

                </div>

                <h5 class="mt-4" style="color: #ef4444; border-bottom: 3px solid #334155; padding-bottom: 5px;">Account Details</h5>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label" style="color: #f8fafc;">Username</label>
                    <input asp-for="Username" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label" style="color: #f8fafc;">Password</label>
                    <input asp-for="Password" class="form-control" type="password" />
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-lg fw-bold" style="background-color: #ef4444; color: white;">Create Account</button>
                </div>
            </div>
        </form>
    </div>
</div>


