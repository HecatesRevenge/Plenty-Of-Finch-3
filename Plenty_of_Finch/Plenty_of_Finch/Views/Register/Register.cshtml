@model RegisterViewModel

@{
    ViewData["Title"] = "Register";
}
<div class="container d-flex justify-content-center align-items-center mt-5 mb-5">
    <div class="card shadow-lg p-4" style="max-width: 800px; width: 100%; background-color: #1e293b; border: 4px solid #334155;">

        <div class="text-center mb-2">
            <h2 style="color: #ef4444;">Join Plenty of Finch!</h2>
            <p class="text" style="color: #f8fafc;">Create your account to find your perfect match.</p>
        </div>



        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="mb-3 text-center">
                <span class="text-danger fw-bold">@Model.ErrorMessage</span>
            </div>
        }

        <form method="post" action="">

            <div class="row">

                <div class="col-md-6">
                    <h5 style="color: #ef4444; border-bottom: 3px solid #334155; padding-bottom: 5px;">Personal Info</h5>


                    <div class="mb-3">
                        <label class="form-label" style="color: #f8fafc;">First Name</label>
                        <input type="text" name="FirstName" value="@Model.FirstName" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="color: #f8fafc;">Last Name</label>
                        <input type="text" name="LastName" value="@Model.LastName" class="form-control" />
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label" style="color: #f8fafc;">Age</label>
                            <input type="number" name="Age" value="@Model.Age" class="form-control" />
                        </div>

                        <div class="col-6 mb-3">
                            <label class="form-label" style="color: #f8fafc;">Gender</label>
                            <select name="Gender" class="form-select">
                                <option value="">Select...</option>
                                <option value="Male @(Model.Gender == "Male")">Male</option>
                                <option value="Female @(Model.Gender == "Female")">Female</option>
                                <option value="Non-Binary @(Model.Gender == "Non-Binary")">Non-Binary</option>
                            </select>
                        </div>


                        <div class="mb-3">
                            <label class="form-label" style="color: #f8fafc;">Email Address</label>
                            <input type="email" name="Email" value="@Model.Email" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" style="color: #f8fafc;">Phone Number</label>
                            <input type="tel" name="Phone" value="@Model.Phone" class="form-control"
                                   placeholder="(215)-867-5309" />
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <h5 style="color: #ef4444; border-bottom: 3px solid #334155; padding-bottom: 5px;">Location</h5>

                    <div class="mb-3">
                        <label class="form-label" style="color: #f8fafc;">Home Address</label>
                        <input type="text" name="Address" value="@Model.Address" class="form-control" />
                    </div>

                    <div class="row">
                        <div class="col-8 mb-3">
                            <label class="form-label" style="color: #f8fafc;">City</label>
                            <input type="text" name="City" value="@Model.City" class="form-control"
                                   placeholder="Philadelphia" />
                        </div>
                        <div class="col-4 mb-3">
                            <label class="form-label" style="color: #f8fafc;">State</label>
                            <input type="text" name="State" value="@Model.State" class="form-control"
                                   maxlength="2" placeholder="PA" />
                        </div>
                    </div>


                    <h5 class="mt-4" style="color: #ef4444; border-bottom: 3px solid #334155; padding-bottom: 5px;">Account Details</h5>

                    <div class="mb-3">
                        <label class="form-label" style="color: #f8fafc;">Username</label>
                        <input type="text" name="Username" value="@Model.Username" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="color: #f8fafc;">Password</label>
                        <input type="password" name="Password" value="" class="form-control" />
                    </div>

                </div>

                <h5 class="mt-4" style="color: #ef4444; border-bottom: 3px solid #334155; padding-bottom: 5px;">Security Questions</h5>
                <p style="color: #94a3b8;">Choose three different questions. These will be used to recover your account.</p>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" style="color: #f8fafc;">Security Question 1</label>
                        <select name="SecurityQuestion1" class="form-select">
                            <option value="">Select a question...</option>
                            @foreach (string question in Model.SecurityQuestionOptions)
                            {
                                if (Model.SecurityQuestion1 == question)
                                {
                                    <option value="@question" selected="selected">@question</option>
                                }
                                else
                                {
                                    <option value="@question">@question</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label" style="color: #f8fafc;">Answer 1</label>
                        <input type="text" name="SecurityAnswer1" value="@Model.SecurityAnswer1" class="form-control"
                               placeholder="Your answer" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" style="color: #f8fafc;">Security Question 2</label>
                        <select name="SecurityQuestion2" class="form-select">
                            <option value="">Select a question...</option>
                            @foreach (string question in Model.SecurityQuestionOptions)
                            {
                                if (Model.SecurityQuestion2 == question)
                                {
                                    <option value="@question" selected="selected">@question</option>
                                }
                                else
                                {
                                    <option value="@question">@question</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label" style="color: #f8fafc;">Answer 2</label>
                        <input type="text" name="SecurityAnswer2" value="@Model.SecurityAnswer2" class="form-control"
                               placeholder="Your answer" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" style="color: #f8fafc;">Security Question 3</label>
                        <select name="SecurityQuestion3" class="form-select">
                            <option value="">Select a question...</option>
                            @foreach (string question in Model.SecurityQuestionOptions)
                            {
                                if (Model.SecurityQuestion3 == question)
                                {
                                    <option value="@question" selected="selected">@question</option>
                                }
                                else
                                {
                                    <option value="@question">@question</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label" style="color: #f8fafc;">Answer 3</label>
                        <input type="text" name="SecurityAnswer3" value="@Model.SecurityAnswer3" class="form-control"
                               placeholder="Your answer" />
                    </div>
                </div>
                <div class="d-grid gap-2 mt-4">

                    <button type="submit" class="btn btn-lg fw-bold" style="background-color: #ef4444; color: white;">Create Account</button>
                </div>

        </form>
    </div>
</div>


